library(tidyverse)
library(tximport)
library(DESeq2)
library(EnsDb.Hsapiens.v86)
STUDY_ID    <- "GSE207923"
SALMON_DIR  <- "outputs/salmon_out"
OUTPUT_DIR  <- "outputs"
# Create required output directory paths
walk(c("metadata", "counts_data/raw_counts", "counts_data/tpm_counts",
"PCA/plot", "PCA/data", "DESeq2"),
~dir.create(file.path(OUTPUT_DIR, .x), recursive = TRUE, showWarnings = FALSE))
# 1. Locate and Verify Quantification Files
samples <- list.dirs(file.path(SALMON_DIR, STUDY_ID), recursive = FALSE, full.names = FALSE)
quant_files <- file.path(SALMON_DIR, STUDY_ID, samples, 'quant.sf')
names(quant_files) <- samples
if(!all(file.exists(quant_files))) stop("Error: Missing quant.sf files detected!")
# 2. Build Experimental Design Metadata Frame
col_data <- data.frame(
row.names = samples,
sample    = samples,
strain    = factor(c(rep("Mock", 12), rep("USA_WA1", 10), rep("New_York", 12)),
levels = c("Mock", "USA_WA1", "New_York")),
time      = factor(c(rep("24hpi", 4), rep("12hpi", 4), rep("6hpi", 4),
rep("24hpi", 3), rep("12hpi", 3), rep("6hpi", 4),
rep("24hpi", 3), rep("12hpi", 5), rep("6hpi", 4)),
levels = c("6hpi", "12hpi", "24hpi"))
)
col_data$group <- factor(paste0(col_data$strain, "_", col_data$time))
write.csv(col_data, file.path(OUTPUT_DIR, "metadata", paste0(STUDY_ID, "_metadata.csv")), row.names = FALSE)
# 3. Import and Summarize Transcript Abundances
tx2gene <- AnnotationDbi::select(EnsDb.Hsapiens.v86, keys = keys(EnsDb.Hsapiens.v86), columns = c('TXID', 'SYMBOL')) %>%
dplyr::select(-GENEID)
txi <- tximport(files = quant_files, type = 'salmon', tx2gene = tx2gene, ignoreTxVersion = TRUE)
# 4. Export Quantified Expression Matrices
data.frame(SYMBOL = rownames(txi$counts), txi$counts) %>%
write.csv(file.path(OUTPUT_DIR, "counts_data/raw_counts", paste0(STUDY_ID, "_raw_counts.csv")), row.names = FALSE)
data.frame(SYMBOL = rownames(txi$abundance), txi$abundance) %>%
write.csv(file.path(OUTPUT_DIR, "counts_data/tpm_counts", paste0(STUDY_ID, "_tpm_counts.csv")), row.names = FALSE)
# 5. Exploratory Quality Control (PCA)
dds <- DESeqDataSetFromTximport(txi = txi, colData = col_data, design = ~ group)
rlog_dds <- rlog(dds)
plotPCA(rlog_dds, intgroup = "group")
ggsave(file.path(OUTPUT_DIR, "PCA/plot", paste0(STUDY_ID, "_PCA.png")), width = 7, height = 5)
plotPCA(rlog_dds, intgroup = "group", returnData = TRUE) %>%
write.csv(file.path(OUTPUT_DIR, "PCA/data", paste0(STUDY_ID, "_pca_coordinates.csv")), row.names = FALSE)
# 6. Differential Expression Analysis & Annotation Helper
dds <- DESeq(dds)
export_annotated_contrast <- function(contrast_vector, file_name) {
res_df <- as.data.frame(results(dds, contrast = contrast_vector))
res_df$SYMBOL <- rownames(res_df)
ann <- AnnotationDbi::select(EnsDb.Hsapiens.v86, keys = res_df$SYMBOL, keytype = "SYMBOL", columns = c("GENENAME", "GENEBIOTYPE"))
ann <- ann[!duplicated(ann$SYMBOL), ]
merge(res_df, ann, by = "SYMBOL", all.x = TRUE) %>%
dplyr::relocate(SYMBOL, GENENAME, GENEBIOTYPE) %>%
write.csv(file.path(OUTPUT_DIR, "DESeq2", file_name), row.names = FALSE)
}
# 7. Extract Specific Pairwise Contrasts
export_annotated_contrast(c("group", "New_York_24hpi", "USA_WA1_24hpi"), paste0(STUDY_ID, "_deseq2_results_NY_vs_WA_24h.csv"))
export_annotated_contrast(c("group", "New_York_24hpi", "USA_WA1_12hpi"), paste0(STUDY_ID, "_deseq2_results_NY24h_vs_WA12h.csv"))
export_annotated_contrast(c("group", "USA_WA1_6hpi", "Mock_6hpi"),       paste0(STUDY_ID, "_deseq2_results_WA_6hpi_vs_Mock.csv"))
library(tidyverse)
library(tximport)
library(DESeq2)
library(EnsDb.Hsapiens.v86)
STUDY_ID    <- "GSE217504"
SALMON_DIR  <- "outputs/salmon_out"
OUTPUT_DIR  <- "outputs"
walk(c("metadata", "counts_data/raw_counts", "counts_data/tpm_counts",
"PCA/plot", "PCA/data", "DESeq2"),
~dir.create(file.path(OUTPUT_DIR, .x), recursive = TRUE, showWarnings = FALSE))
# 1. Locate and Verify Quantification Files
samples <- list.dirs(file.path(SALMON_DIR, STUDY_ID), recursive = FALSE, full.names = FALSE)
quant_files <- file.path(SALMON_DIR, STUDY_ID, samples, 'quant.sf')
names(quant_files) <- samples
if(!all(file.exists(quant_files))) stop("Error: Missing quant.sf files detected!")
# 2. Build Experimental Design Metadata Frame via GSM-Mapping Template
# This maps each run to its exact biological condition as described in GEO
metadata_template <- data.frame(
gsm = paste0("GSM6720", 772:804),
infection = c(rep("infected", 24), rep("mock", 9)),
time = c(
rep("48h", 3), rep("24h", 3), rep("12h", 3), rep("7h", 3),
rep("4h", 3),  rep("2h", 3),  rep("1h", 3),  rep("0h", 3), # Infected blocks
rep("48h", 3), rep("12h", 3), rep("4h", 3)                  # Mock blocks
)
)
# Extract GSM codes from directory names to align files with conditions
gsm_extracted <- str_extract(samples, "GSM6720\\d+")
col_data <- data.frame(
row.names = samples,
sample    = samples,
infection = factor(metadata_template$infection[match(gsm_extracted, metadata_template$gsm)], levels = c("mock", "infected")),
time      = factor(metadata_template$time[match(gsm_extracted, metadata_template$gsm)], levels = c("0h", "1h", "2h", "4h", "7h", "12h", "24h", "48h"))
)
col_data
col_data$group <- factor(paste0(col_data$infection, "_", col_data$time))
# Extract GSM codes from directory names to align files with conditions
gsm_extracted <- str_extract(samples, "GSM6720\\d+")

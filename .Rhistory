gsm = paste0("GSM6720", 772:804),
infection = c(rep("infected", 24), rep("mock", 9)),
time = c(
rep("48h", 3), rep("24h", 3), rep("12h", 3), rep("7h", 3),
rep("4h", 3),  rep("2h", 3),  rep("1h", 3),  rep("0h", 3), # Infected blocks
rep("48h", 3), rep("12h", 3), rep("4h", 3)                  # Mock blocks
)
)
# Extract GSM codes from directory names to align files with conditions
